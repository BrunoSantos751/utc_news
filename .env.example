# Canal usado pelo LISTEN/NOTIFY
UTC_NEWS_NOTIFY_CHANNEL=utc_news_email

# Tempo de espera para agrupar notificacoes consecutivas antes de enviar o email
UTC_NEWS_NOTIFY_DEBOUNCE_SECONDS=2.0

# DSN do PostgreSQL usado pelo listener
UTC_NEWS_DSN=dbname=utc_news user=postgres password=123 host=localhost port=5432

# Configuracoes SMTP
UTC_NEWS_SMTP_HOST=smtp.gmail.com
UTC_NEWS_SMTP_PORT=587
UTC_NEWS_SMTP_USER=seu_email_aqui@gmail.com
UTC_NEWS_SMTP_PASS=sua_senha_aqui
UTC_NEWS_SMTP_FROM=Jornal UTC <seu_email_aqui@gmail.com>

# Assunto do email
UTC_NEWS_EMAIL_SUBJECT=Jornal UTC - Manha
